APP_NAME="Finanças da Casa"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=warning

# DOCKER — use estes valores com docker compose (servico mysql na rede interna)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=financas_casa
DB_USERNAME=financas
DB_PASSWORD=secret

# LOCAL — comente o bloco DOCKER acima e descomente abaixo para Laragon
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3307
# DB_DATABASE=financas_casa
# DB_USERNAME=root
# DB_PASSWORD=

# Sessao/cache em Redis (muito mais rapido que database no Docker Windows)
SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# Aquecimento automatico de config/route/view cache no startup (docker/scripts/start-app.sh)
LARAVEL_WARM_CACHE=true
